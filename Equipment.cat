    <selectionEntry type="upgrade" import="true" name="Hellbound Soul Contract" hidden="false" id="a2d4-cd33-46c4-3b81">
      <profiles>
        <profile name="Hellbound Soul Contract" typeId="7079-589c-df69-fa7e" typeName="Battlekit" hidden="false" id="4fa4-3134-d167-8099">
          <characteristics>
            <characteristic name="Type" typeId="3f15-74a1-4d35-3642">Equipment</characteristic>
            <characteristic name="Range" typeId="2b32-2f45-9c06-7a77"/>
            <characteristic name="Keywords" typeId="5093-5528-b08f-1496"/>
            <characteristic name="Rules" typeId="4834-43a9-1c93-9062">**Fiery Exodus**: If a model with a Hellbound Soul Contract is taken Out of Action, before removing it from the battlefield add 1 BLOOD MARKER to each enemy model that is within 1” of it. Models that have the NEGATE FIRE Keyword are not affected by this special rule.</characteristic>
          </characteristics>
        </profile>
      </profiles>
