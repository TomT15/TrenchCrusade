      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="e89d-79d5-ec81-3aae" includeChildSelections="false"/>
      </constraints>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Musical Instrument" hidden="false" id="d6b0-fb63-288a-420a">
      <profiles>
        <profile name="Musical Instrument" typeId="7079-589c-df69-fa7e" typeName="Battlekit" hidden="false" id="ed7c-0353-5a9d-b903">
          <characteristics>
            <characteristic name="Type" typeId="3f15-74a1-4d35-3642">Equipment</characteristic>
            <characteristic name="Range" typeId="2b32-2f45-9c06-7a77"/>
            <characteristic name="Keywords" typeId="5093-5528-b08f-1496">HELD</characteristic>
            <characteristic name="Rules" typeId="4834-43a9-1c93-9062">**Fanfare**: Add +1 DICE to Risky Success Rolls for friendly models that are taking a Dash ACTION and are within 4” of one or more models with a Musical Instrument.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <infoLinks>
        <infoLink name="Held" id="27f6-3527-bc04-17bd" hidden="false" type="rule" targetId="1220-c65a-89ed-96a7"/>
      </infoLinks>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="b35c-7505-09f3-9f11" includeChildSelections="false"/>
      </constraints>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Shovel" hidden="false" id="d0a8-ad68-ad47-83f5">
      <profiles>
        <profile name="Shovel" typeId="7079-589c-df69-fa7e" typeName="Battlekit" hidden="false" id="41f3-4b8e-6736-1db8">
          <characteristics>
            <characteristic name="Type" typeId="3f15-74a1-4d35-3642">Equipment</characteristic>
            <characteristic name="Range" typeId="2b32-2f45-9c06-7a77"/>
            <characteristic name="Keywords" typeId="5093-5528-b08f-1496"/>
            <characteristic name="Rules" typeId="4834-43a9-1c93-9062">**Dug In**: A model equipped with a Shovel that starts the game on Open terrain has the COVER Keyword until it moves away from its starting position. In addition, a model equipped with a Shovel can use it as a 2-Handed Melee Weapon instead of using any other Melee Weapons it has.</characteristic>
          </characteristics>
        </profile>
      </profiles>
