            <cost name="Glory Points" typeId="f3bb-a7e6-d476-f60b" value="0"/>
          </costs>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Urn of Bitter Ashes " hidden="true" id="f451-eff3-bd36-29ff" sortIndex="7">
          <profiles>
            <profile name="Urn of Bitter Ashes " typeId="7079-589c-df69-fa7e" typeName="Battlekit" hidden="false" id="cc13-67a7-5431-2fdd">
              <characteristics>
                <characteristic name="Type" typeId="3f15-74a1-4d35-3642">Equipment</characteristic>
                <characteristic name="Range" typeId="2b32-2f45-9c06-7a77">-</characteristic>
                <characteristic name="Keywords" typeId="5093-5528-b08f-1496">-</characteristic>
                <characteristic name="Rules" typeId="4834-43a9-1c93-9062">Add -1 DICE to the roll for Ranged Attacks that target a model that has the Urn of Bitter Ashes or that is within 3&quot; of the model with the Urn of Bitter Ashes</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <constraints>
