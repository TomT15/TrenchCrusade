            </conditionGroup>
          </conditionGroups>
        </modifier>
        <modifier type="set" value="1" field="7385-348a-8951-199e">
          <conditions>
            <condition type="atLeast" value="1" field="selections" scope="parent" childId="bd82-c719-4abf-c104" shared="true" childName="Led by a Lord of Tumours"/>
          </conditions>
        </modifier>
      </modifiers>
    </selectionEntry>
    <selectionEntry type="model" import="true" name="Corpse Guard" hidden="false" id="7e0b-de14-f14c-8ea0">
      <categoryLinks>
