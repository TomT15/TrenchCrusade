        <selectionEntry type="upgrade" import="true" name="Plague Almoner" hidden="false" id="ca6e-b552-9a9c-9288">
          <profiles>
            <profile name="Plague Almoner" typeId="7079-589c-df69-fa7e" typeName="Battlekit" hidden="false" id="1780-92d2-3e63-3c71">
              <characteristics>
                <characteristic name="Type" typeId="3f15-74a1-4d35-3642"/>
                <characteristic name="Range" typeId="2b32-2f45-9c06-7a77"/>
                <characteristic name="Keywords" typeId="5093-5528-b08f-1496"/>
                <characteristic name="Rules" typeId="4834-43a9-1c93-9062">If you convert an Injury Roll into a Bloodbath Roll for an attack made by this Plague Knight, the cost in BLOOD MARKERS and/or INFECTION MARKERS of the Bloodbath Roll is reduced by 1.</characteristic>
