            <modifier type="decrement" value="1" field="3980-b0ea-d058-048d">
              <conditionGroups>
                <conditionGroup type="and">
                  <conditions>
                    <condition type="atLeast" value="1" field="selections" scope="parent" childId="4974-c044-9d11-53cb" shared="true"/>
