              <characteristics>
                <characteristic name="Description" typeId="2ecd-b4ff-9e78-a8e2">When an enemy model takes a Retreat ACTION within 1” of a model with the Lockjaw Bite Strain, place 1 INFECTION MARKER next to the model taking the retreat (before any melee attacks are made against the retreating model).</characteristic>
              </characteristics>
            </profile>
          </profiles>
