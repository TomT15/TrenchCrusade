            </modifier>
          </modifiers>
        </profile>
        <profile name="Undead Fortitude" typeId="058c-866b-6487-ccc4" typeName="Ability" hidden="false" id="1e0f-7803-5158-bf35">
          <characteristics>
            <characteristic name="Description" typeId="2ecd-b4ff-9e78-a8e2">Add -1 INJURY DICE to Injury Rolls for a Hound of the Cult of the Black Grail unless the attack has the FIRE Keyword.</characteristic>
          </characteristics>
        </profile>
