        <profile name="Undead Fortitude" typeId="058c-866b-6487-ccc4" typeName="Ability" hidden="false" id="dae4-94a1-1c22-0c9a">
          <characteristics>
            <characteristic name="Description" typeId="2ecd-b4ff-9e78-a8e2">Add -1 INJURY DICE to Injury Rolls for a Lord of Tumours unless the attack has the FIRE Keyword.</characteristic>
          </characteristics>
        </profile>
        <profile name="Beelzebub’s Touch" typeId="058c-866b-6487-ccc4" typeName="Ability" hidden="false" id="f662-8943-c553-035f">
          <characteristics>
            <characteristic name="Description" typeId="2ecd-b4ff-9e78-a8e2">Whenever a Melee Attack made by a Lord of Tumours causes any BLOOD MARKERS or INFECTION MARKERS to be placed on the target, place 1 extra INFECTION MARKER next to the target model</characteristic>
          </characteristics>
        </profile>
        <profile name="Crushing Blows" typeId="058c-866b-6487-ccc4" typeName="Ability" hidden="false" id="25bc-e870-f2a0-877a">
          <characteristics>
            <characteristic name="Description" typeId="2ecd-b4ff-9e78-a8e2">A Lord of Tumours can make a Crushing Blows Melee Attack even if it does not have any Melee Weapons, or instead of using any Melee Weapons that it has. If it does so, this Melee Attack has the CLEAVE 2 Keyword.</characteristic>
          </characteristics>
        </profile>
