      <selectionEntries>
        <selectionEntry type="upgrade" import="true" name="Broken Crown" hidden="true" id="ed7f-e91c-7eca-840a" sortIndex="5">
          <profiles>
            <profile name="Broken Crown" typeId="7079-589c-df69-fa7e" typeName="Battlekit" hidden="false" id="7cac-e423-0e4d-b763">
              <characteristics>
                <characteristic name="Type" typeId="3f15-74a1-4d35-3642">Equipment</characteristic>
                <characteristic name="Range" typeId="2b32-2f45-9c06-7a77">-</characteristic>
                <characteristic name="Keywords" typeId="5093-5528-b08f-1496">-</characteristic>
                <characteristic name="Rules" typeId="4834-43a9-1c93-9062">Each time the model with the Broken Crown is Activated, before carrying out any ACTIONS with the model, place 1 INFECTION MARKER next to each enemy model within 1&quot; of the model with the Broken Crown.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <constraints>
            <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="2b00-d6a9-585a-365b" includeChildSelections="true"/>
          </constraints>
