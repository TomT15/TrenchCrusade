    <selectionEntryGroup name="Fireteams" id="1ede-384e-2abd-0c45" hidden="false">
      <selectionEntries>
        <selectionEntry type="upgrade" import="true" name="Mind Linked" hidden="true" id="8858-f2cf-be66-80ce">
          <profiles>
            <profile name="Mind Linked" typeId="7079-589c-df69-fa7e" typeName="Battlekit" hidden="false" id="7fd0-a83c-445b-40ff">
              <characteristics>
                <characteristic typeId="3f15-74a1-4d35-3642" name="Type"/>
